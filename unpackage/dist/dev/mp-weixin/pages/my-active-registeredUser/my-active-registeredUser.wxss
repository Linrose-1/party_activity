/* 水平间距 */
/* 水平间距 */
.page-container.data-v-90acde2c {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f7fa;
}
.activity-header-card.data-v-90acde2c {
  background-color: #fff;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.activity-header-card .header-title-row.data-v-90acde2c {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.activity-header-card .header-title-row .header-title.data-v-90acde2c {
  font-size: 32rpx;
  font-weight: 600;
  color: #303133;
  margin-left: 12rpx;
}
.activity-header-card .header-info-row.data-v-90acde2c {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #606266;
  margin-bottom: 12rpx;
}
.activity-header-card .header-info-row .info-text.data-v-90acde2c {
  margin-left: 12rpx;
}
.user-list-scroll.data-v-90acde2c {
  flex: 1;
  height: 1px;
}
.user-list.data-v-90acde2c {
  padding: 0 24rpx 24rpx;
}
.user-card.data-v-90acde2c {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}
.card-header.data-v-90acde2c {
  display: flex;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f2f5;
}
.avatar.data-v-90acde2c {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #eee;
  flex-shrink: 0;
}
.user-info.data-v-90acde2c {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.name-row.data-v-90acde2c {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}
.nickname.data-v-90acde2c {
  font-size: 30rpx;
  font-weight: 700;
  color: #303133;
}

/* 专属免费标签样式 */
.free-badge.data-v-90acde2c {
  font-size: 20rpx;
  color: #FF62B1;
  background: rgba(255, 98, 177, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-weight: bold;
  border: 1rpx solid rgba(255, 98, 177, 0.2);
}
.time.data-v-90acde2c {
  font-size: 24rpx;
  color: #909399;
}
.status-tag.data-v-90acde2c {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  font-weight: 500;
}
.status-tag.status-pending.data-v-90acde2c {
  background-color: #fdf6ec;
  color: #FF7900;
}
.status-tag.status-confirmed.data-v-90acde2c {
  background-color: #f0f9eb;
  color: #67c23a;
}
.status-tag.status-rejected.data-v-90acde2c, .status-tag.status-refunded.data-v-90acde2c {
  background-color: #fef0f0;
  color: #f56c6c;
}
.status-tag.status-substitute.data-v-90acde2c, .status-tag.status-default.data-v-90acde2c {
  background-color: #f4f4f5;
  color: #909399;
}
.payment-proof.data-v-90acde2c {
  padding: 24rpx 0;
  display: flex;
  align-items: flex-start;
}
.payment-proof .proof-label.data-v-90acde2c {
  font-size: 28rpx;
  color: #606266;
  margin-right: 20rpx;
}
.payment-proof .proof-image.data-v-90acde2c {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  border: 1rpx solid #eee;
}
.payment-proof-empty.data-v-90acde2c {
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #bbb;
  text-align: center;
  font-style: italic;
}

/* 核销状态显示样式 */
.verify-status-row.data-v-90acde2c {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.verify-status-row .v-label.data-v-90acde2c {
  font-size: 26rpx;
  color: #666;
}
.verify-status-row .v-done.data-v-90acde2c {
  font-size: 26rpx;
  color: #67c23a;
  font-weight: bold;
}
.verify-status-row .v-wait.data-v-90acde2c {
  font-size: 26rpx;
  color: #FF7900;
  font-weight: bold;
}
.rejection-reason.data-v-90acde2c {
  display: flex;
  align-items: flex-start;
  background-color: #fef0f0;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}
.rejection-reason .reason-label.data-v-90acde2c {
  font-size: 26rpx;
  font-weight: 600;
  color: #f56c6c;
  margin: 0 10rpx;
  flex-shrink: 0;
}
.rejection-reason .reason-text.data-v-90acde2c {
  font-size: 26rpx;
  color: #f56c6c;
  flex: 1;
}
.card-actions.data-v-90acde2c {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  padding-top: 24rpx;
  margin-top: 24rpx;
  border-top: 1rpx solid #f0f2f5;
}
.btn.data-v-90acde2c {
  margin: 0;
  padding: 0 40rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 34rpx;
  font-size: 26rpx;
  font-weight: bold;
}
.btn-reject.data-v-90acde2c {
  background-color: #fff;
  color: #f56c6c;
  border: 1px solid #f56c6c;
}
.btn-confirm.data-v-90acde2c {
  background: linear-gradient(135deg, #FF9500, #FF7900);
  color: #fff;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 121, 0, 0.2);
}
.empty-state.data-v-90acde2c {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: #909399;
}
.empty-state .empty-text.data-v-90acde2c {
  font-size: 28rpx;
  margin-top: 20rpx;
}
.loading-more.data-v-90acde2c {
  padding: 20rpx 0;
}