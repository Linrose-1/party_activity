/* 自定义全局主题色变量 */
/* 原有样式完全保留，不修改任何原有类 */
.container.data-v-03f92355 {
  background-color: #f9f9f9;
  min-height: 100vh;
  padding: 30rpx 30rpx 140rpx;
  box-sizing: border-box;
}
.page-header.data-v-03f92355 {
  margin-bottom: 30rpx;
}
.header-title-box.data-v-03f92355 {
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}
.header-title-box .page-title.data-v-03f92355 {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}
.header-title-box .page-subtitle.data-v-03f92355 {
  font-size: 26rpx;
  color: #666;
}
.standard-card.data-v-03f92355 {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}
.standard-title.data-v-03f92355 {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}
.standard-title text.data-v-03f92355 {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}
.standard-grid.data-v-03f92355 {
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
}
.standard-item.data-v-03f92355 {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background-color: #f5f5f5;
}
.standard-item .score-range.data-v-03f92355 {
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}
.standard-item .score-desc.data-v-03f92355 {
  font-size: 22rpx;
  opacity: 0.9;
}
.standard-item.level-6.data-v-03f92355 {
  background-color: #FFF0E6;
  color: #FF6A00;
}
.standard-item.level-5.data-v-03f92355 {
  background-color: #FFF7E6;
  color: #FF9C38;
}
.standard-item.level-4.data-v-03f92355 {
  background-color: #E8F5E9;
  color: #4CAF50;
}
.standard-item.level-3.data-v-03f92355 {
  background-color: #E3F2FD;
  color: #2196F3;
}
.standard-item.level-2.data-v-03f92355 {
  background-color: #FFF3E0;
  color: #FF9800;
}
.standard-item.level-1.data-v-03f92355 {
  background-color: #FBE9E7;
  color: #FF5722;
}

/* 新增：填写进度提示条 */
.progress-tip.data-v-03f92355 {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 20rpx;
  padding: 16rpx 24rpx;
  background-color: #FFF7ED;
  border-radius: 12rpx;
  border: 1rpx solid #FFE0B2;
  /* 全部完成时切换为绿色主题 */
}
.progress-tip text.data-v-03f92355 {
  font-size: 26rpx;
  color: #FF8C00;
}
.progress-tip .tip-highlight.data-v-03f92355 {
  font-weight: bold;
  color: #FF6B00;
}
.progress-tip.all-done.data-v-03f92355 {
  background-color: #F1F8E9;
  border-color: #C5E1A5;
}
.progress-tip.all-done text.data-v-03f92355 {
  color: #4CAF50;
}
.score-sections.data-v-03f92355 {
  margin-bottom: 80rpx;
}
.footer.data-v-03f92355 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1px solid #f0f0f0;
  z-index: 100;
}

/* 修复：button → view，消除 &[disabled] 和 &::after SCSS 嵌套编译报错 */
.submit-btn.data-v-03f92355 {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(to right, #FF8C00, #FF6B00);
  color: white;
  border-radius: 44rpx;
  font-size: 32rpx;
  text-align: center;
  font-weight: 500;
  box-sizing: border-box;
  /* 提交中时显示禁用样式 */
}
.submit-btn.is-disabled.data-v-03f92355 {
  background: #c8c9cc;
  color: rgba(255, 255, 255, 0.8);
}