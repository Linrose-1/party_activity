/* 水平间距 */
/* 水平间距 */
/* 自定义全局主题色变量 */
.container.data-v-12e513cf {
  background-color: #f8f9fa;
  padding-bottom: 120rpx;
  min-height: 100vh;
}

/* 1. 顶部固定区域 */
.fixed-header.data-v-12e513cf {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fff;
  z-index: 100;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.search-location-bar.data-v-12e513cf {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}
.search-location-bar .location-trigger.data-v-12e513cf {
  display: flex;
  align-items: center;
  gap: 4rpx;
  max-width: 140rpx;
}
.search-location-bar .location-trigger .city-text.data-v-12e513cf {
  font-size: 26rpx;
  font-weight: bold;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.search-location-bar .search-box.data-v-12e513cf {
  flex: 1;
  background: #f5f5f5;
  border-radius: 30rpx;
  padding: 12rpx 24rpx;
  display: flex;
  align-items: center;
}
.search-location-bar .search-box .search-input.data-v-12e513cf {
  flex: 1;
  font-size: 26rpx;
  margin-left: 10rpx;
}
.search-location-bar .scan-trigger.data-v-12e513cf {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx;
  transition: transform 0.1s;
}
.search-location-bar .scan-trigger.data-v-12e513cf:active {
  transform: scale(0.9);
  opacity: 0.8;
}

/* 2. 吸顶标签筛选 */
.fixed-header.data-v-12e513cf {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fff;
  z-index: 100;
}

/* 新的双行筛选容器 */
.filter-rows-container.data-v-12e513cf {
  background: #fff;
  padding: 10rpx 0 20rpx;
  margin-bottom: 10rpx;
  /* --- 核心吸顶代码 --- */
  position: -webkit-sticky;
  position: sticky;
  /* 开启粘性布局 */
  top: 100rpx;
  /* 这里的 100rpx 必须等于 .header-placeholder 的高度 */
  z-index: 99;
  /* 确保在列表内容上方，但在 fixed-header (z-index: 100) 下方 */
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.02);
  /* 吸顶时增加一点微弱投影，区分内容 */
  /* ------------------ */
}
.filter-rows-container .filter-row-scroll.data-v-12e513cf {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 16rpx;
}
.filter-rows-container .filter-row-scroll.data-v-12e513cf:last-child {
  margin-bottom: 0;
}
.filter-rows-container .tabs-line.data-v-12e513cf {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}
.filter-rows-container .row-label.data-v-12e513cf {
  font-size: 24rpx;
  color: #999;
  margin-right: 10rpx;
  flex-shrink: 0;
}
.filter-rows-container .tab-pill.data-v-12e513cf {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  margin-right: 16rpx;
  transition: all 0.2s;
  border: 1rpx solid transparent;
}
.filter-rows-container .tab-pill.active.data-v-12e513cf {
  background: rgba(255, 98, 177, 0.1);
  color: #FF62B1;
  border-color: #FF62B1;
  font-weight: bold;
}
.header-placeholder.data-v-12e513cf {
  height: 180rpx;
}
.swiper-section.data-v-12e513cf {
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
  height: 260rpx;
}
.swiper-section .swiper.data-v-12e513cf {
  height: 100%;
}
.swiper-section .swiper-image.data-v-12e513cf {
  width: 100%;
  height: 100%;
}
.activity-list.data-v-12e513cf {
  padding: 10rpx 30rpx;
}
.empty-state.data-v-12e513cf {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}
.empty-state .reset-link.data-v-12e513cf {
  color: #FF62B1;
  margin-top: 20rpx;
  text-decoration: underline;
}

/* ── 筛选区域 ── */
/* ── 聚会列表 ── */
.activity-list.data-v-12e513cf {
  padding: 0 32rpx;
}
.no-more-content.data-v-12e513cf {
  text-align: center;
  color: #999;
  padding: 30rpx 0;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* ── 底部操作栏 ── */
.action-bar.data-v-12e513cf {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  padding: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}
.action-btn.data-v-12e513cf {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx;
  border-radius: 16rpx;
  font-weight: 500;
  font-size: 32rpx;
}
.action-btn text.data-v-12e513cf {
  margin-left: 12rpx;
}
.register-btn.data-v-12e513cf {
  background: linear-gradient(to right, #FF62B1, #FF85C1);
  color: white;
  box-shadow: 0 6rpx 16rpx rgba(255, 98, 177, 0.3);
}