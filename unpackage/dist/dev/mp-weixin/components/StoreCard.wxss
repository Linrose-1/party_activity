/* 水平间距 */
/* 自定义全局主题色变量 */
.store-card.data-v-8cae2ec5 {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
}
.store-card.data-v-8cae2ec5:active {
  background-color: #fafafa;
}
.main-body.data-v-8cae2ec5 {
  display: flex;
  gap: 24rpx;
}

/* ── 左侧 ── */
.card-left.data-v-8cae2ec5 {
  flex-shrink: 0;
  width: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.card-image-wrapper.data-v-8cae2ec5 {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #f5f5f5;
  margin-bottom: 16rpx;
}
.card-image.data-v-8cae2ec5 {
  width: 100%;
  height: 100%;
}
.card-interaction-row.data-v-8cae2ec5 {
  display: flex;
  justify-content: space-between;
  width: 100%;
  padding: 0 4rpx;
}
.card-interaction-row .mini-interaction.data-v-8cae2ec5 {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: #999;
}
.card-interaction-row .mini-interaction.active.data-v-8cae2ec5 {
  color: #FF62B1;
}
.card-interaction-row .mini-interaction text.data-v-8cae2ec5 {
  line-height: 1;
}

/* ── 右侧 ── */
.card-content.data-v-8cae2ec5 {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.card-header.data-v-8cae2ec5 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.card-header .store-name.data-v-8cae2ec5 {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.card-header .distance-badge.data-v-8cae2ec5 {
  font-size: 22rpx;
  color: #888;
  margin-left: 10rpx;
}
.store-desc.data-v-8cae2ec5 {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
}
.price-info.data-v-8cae2ec5 {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.price-info .price-label.data-v-8cae2ec5 {
  font-size: 22rpx;
  color: #999;
}
.price-info .price-value.data-v-8cae2ec5 {
  font-size: 28rpx;
  color: #FF62B1;
  font-weight: bold;
}
.card-footer.data-v-8cae2ec5 {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}
.action-buttons.data-v-8cae2ec5 {
  display: flex;
  gap: 16rpx;
}
.btn.data-v-8cae2ec5 {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-weight: 500;
}
.btn.btn-primary-light.data-v-8cae2ec5 {
  background-color: rgba(255, 98, 177, 0.08);
  color: #FF62B1;
}
.btn.btn-outline.data-v-8cae2ec5 {
  border: 1rpx solid #FF62B1;
  color: #FF62B1;
}

/* ── 阅读留痕 ── */
.post-view-trace.data-v-8cae2ec5 {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f2f2f2;
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}
.view-avatar-row.data-v-8cae2ec5 {
  display: flex;
  align-items: center;
}
.view-avatar-row .tiny-avatar.data-v-8cae2ec5 {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
  margin-right: -10rpx;
}
.view-avatar-row .silent-avatar.data-v-8cae2ec5 {
  border-color: #FF62B1 !important;
}
.view-avatar-row .view-count-txt.data-v-8cae2ec5 {
  font-size: 22rpx;
  color: #bbb;
  margin-left: 20rpx;
}
.status-badge.data-v-8cae2ec5 {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.status-badge.status-normal.data-v-8cae2ec5 {
  background: rgba(46, 204, 113, 0.1);
  color: #2ecc71;
}
.status-badge.status-pending.data-v-8cae2ec5 {
  background: rgba(243, 156, 18, 0.1);
  color: #f39c12;
}
.status-badge.status-failed.data-v-8cae2ec5 {
  background: rgba(245, 108, 108, 0.1);
  color: #f56c6c;
}
.helper-tag.data-v-8cae2ec5 {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  color: #888;
  font-size: 20rpx;
}