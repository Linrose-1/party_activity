/* 水平间距 */
/* ── 卡片容器 ── */
.store-card.data-v-8cae2ec5 {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.store-card.data-v-8cae2ec5:active {
  background-color: #f9f9f9;
}

/* ── 左侧：图片 + 互动统计 ── */
.card-left.data-v-8cae2ec5 {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  width: 180rpx;
}
.card-image-wrapper.data-v-8cae2ec5 {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #f5f5f5;
}
.card-image.data-v-8cae2ec5 {
  width: 100%;
  height: 100%;
}

/* 赞踩评论行：图片正下方，三项均分宽度 */
.card-interaction-row.data-v-8cae2ec5 {
  width: 100%;
  display: flex;
  justify-content: space-around;
  align-items: center;
}
.mini-interaction.data-v-8cae2ec5 {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: #999;
}
.mini-interaction.active.data-v-8cae2ec5 {
  color: #ff6b00;
}

/* ── 右侧内容区 ── */
.card-content.data-v-8cae2ec5 {
  flex: 1;
  min-width: 0;
  /* 允许 flex 子元素正常收缩 */
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

/* ── 1. 头部：店名 + 距离 ── */
.card-header.data-v-8cae2ec5 {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}
.store-name.data-v-8cae2ec5 {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  margin-right: 10rpx;
}
.distance-badge.data-v-8cae2ec5 {
  font-size: 22rpx;
  color: #666;
  flex-shrink: 0;
  padding-top: 4rpx;
}

/* ── 2. 中部：描述 + 均价 ── */
.card-body.data-v-8cae2ec5 {
  flex: 1;
  margin-bottom: 12rpx;
}
.store-desc.data-v-8cae2ec5 {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 均价：独占一行，文字再长也不变形，极端长度时自动换行兜底 */
.price-info.data-v-8cae2ec5 {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-top: 10rpx;
  flex-wrap: wrap;
}
.price-info .price-label.data-v-8cae2ec5 {
  font-size: 22rpx;
  color: #999;
}
.price-info .price-value.data-v-8cae2ec5 {
  font-size: 26rpx;
  color: #ff6b00;
  font-weight: 600;
}

/* ── 3. 底部：按钮组 ── */
.card-footer.data-v-8cae2ec5 {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}
.action-buttons.data-v-8cae2ec5 {
  display: flex;
  gap: 12rpx;
}

/* 按钮基础样式 */
.btn.data-v-8cae2ec5 {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  min-width: 120rpx;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 详情按钮：浅橙色背景 */
.btn-primary-light.data-v-8cae2ec5 {
  background-color: #fff5ec;
  color: #ff6b00;
  border: 1rpx solid rgba(255, 107, 0, 0.25);
}

/* 发起聚会按钮：空心橙边框 */
.btn-outline.data-v-8cae2ec5 {
  border: 1rpx solid #ff6b00;
  color: #ff6b00;
  background-color: transparent;
}