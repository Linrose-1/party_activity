/* 水平间距 */
/* ── 卡片容器 ── */
.store-card.data-v-8cae2ec5 {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.store-card.data-v-8cae2ec5:active {
  background-color: #f9f9f9;
}

/* ── 左侧：图片 + 互动统计 ── */
.card-left.data-v-8cae2ec5 {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  width: 180rpx;
}
.card-image-wrapper.data-v-8cae2ec5 {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #f5f5f5;
}
.card-image.data-v-8cae2ec5 {
  width: 100%;
  height: 100%;
}

/* 赞踩评论行 */
.card-interaction-row.data-v-8cae2ec5 {
  width: 100%;
  display: flex;
  justify-content: space-around;
  align-items: center;
}
.mini-interaction.data-v-8cae2ec5 {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: #999;
}
.mini-interaction.active.data-v-8cae2ec5 {
  color: #ff6b00;
}

/* ── 右侧内容区 ── */
.card-content.data-v-8cae2ec5 {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

/* ── 1. 头部 ── */
.card-header.data-v-8cae2ec5 {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}
.store-name.data-v-8cae2ec5 {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  margin-right: 10rpx;
}

/* 距离标签 */
.distance-badge.data-v-8cae2ec5 {
  font-size: 22rpx;
  color: #666;
  flex-shrink: 0;
  padding-top: 4rpx;
}

/* 审核状态标签 */
.status-badge.data-v-8cae2ec5 {
  flex-shrink: 0;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 500;
}
.status-badge text.data-v-8cae2ec5 {
  font-size: 20rpx;
}
.status-normal.data-v-8cae2ec5 {
  background: #e8f7ee;
  color: #27ae60;
}
.status-pending.data-v-8cae2ec5 {
  background: #fff8e6;
  color: #f39c12;
}
.status-failed.data-v-8cae2ec5 {
  background: #fff0f0;
  color: #e74c3c;
}

/* ── 2. 中部 ── */
.card-body.data-v-8cae2ec5 {
  flex: 1;
  margin-bottom: 12rpx;
}
.store-desc.data-v-8cae2ec5 {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 均价 */
.price-info.data-v-8cae2ec5 {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-top: 10rpx;
  flex-wrap: wrap;
}
.price-info .price-label.data-v-8cae2ec5 {
  font-size: 22rpx;
  color: #999;
}
.price-info .price-value.data-v-8cae2ec5 {
  font-size: 26rpx;
  color: #ff6b00;
  font-weight: 600;
}

/* 帮创标识：图片正下方，宽度与图片对齐，居中显示 */
.helper-tag.data-v-8cae2ec5 {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: #f5f5f5;
  color: #888;
  font-size: 20rpx;
  padding: 6rpx 0;
  border-radius: 20rpx;
  border: 1rpx solid #e8e8e8;
}
.helper-tag text.data-v-8cae2ec5 {
  font-size: 20rpx;
}

/* ── 3. 底部按钮 ── */
.card-footer.data-v-8cae2ec5 {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}
.action-buttons.data-v-8cae2ec5 {
  display: flex;
  gap: 12rpx;
}
.btn.data-v-8cae2ec5 {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  min-width: 120rpx;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 详情按钮：浅橙色背景 */
.btn-primary-light.data-v-8cae2ec5 {
  background-color: #fff5ec;
  color: #ff6b00;
  border: 1rpx solid rgba(255, 107, 0, 0.25);
}

/* 发起聚会 / 编辑聚店：空心橙边框 */
.btn-outline.data-v-8cae2ec5 {
  border: 1rpx solid #ff6b00;
  color: #ff6b00;
  background-color: transparent;
}