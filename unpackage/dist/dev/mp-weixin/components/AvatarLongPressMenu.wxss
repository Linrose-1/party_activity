/* 自定义全局主题色变量 */
.menu-card.data-v-5571075f {
  width: 620rpx;
  background-color: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  position: relative;
}

/* --- 头部样式优化 --- */
.card-header.data-v-5571075f {
  background: linear-gradient(135deg, #FF7009, #FF9A44);
  padding: 50rpx 30rpx;
  display: flex;
  align-items: center;
  position: relative;
}
.avatar-wrapper.data-v-5571075f {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  overflow: hidden;
  margin-right: 24rpx;
  background: #f0f0f0;
}
.menu-avatar.data-v-5571075f {
  width: 100%;
  height: 100%;
}
.user-info.data-v-5571075f {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.user-info .user-name.data-v-5571075f {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.user-info .user-desc.data-v-5571075f {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

/* 第一行标签：毛玻璃质感 */
.mini-tags-line.data-v-5571075f {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 4rpx;
}
.mini-tag.data-v-5571075f {
  display: inline-block;
  font-size: 20rpx;
  color: #fff;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  line-height: 1.2;
}
.mini-tag.data-v-5571075f:active {
  background: rgba(255, 255, 255, 0.3);
}

/* 信用信息行容器 */
.credit-info-row.data-v-5571075f {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

/* 独立胶囊通用样式 */
.mini-capsule.data-v-5571075f {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  /* 稍微提高一点透明度，让边界更清晰 */
  padding: 6rpx 18rpx;
  border-radius: 40rpx;
  gap: 6rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  width: -webkit-fit-content;
  width: fit-content;
  transition: background 0.2s;
}
.mini-capsule .capsule-text.data-v-5571075f {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
  line-height: 1;
}
.mini-capsule.data-v-5571075f:active {
  background: rgba(255, 255, 255, 0.3);
}
.close-icon.data-v-5571075f {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 10rpx;
  opacity: 0.8;
}

/* --- 操作网格优化 --- */
.action-grid.data-v-5571075f {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 50rpx 20rpx;
  padding: 50rpx 20rpx 60rpx;
}
.grid-item.data-v-5571075f {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
}
.grid-item.data-v-5571075f:active {
  transform: scale(0.92);
  opacity: 0.8;
}
.grid-item .icon-box.data-v-5571075f {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border: 2rpx solid #FF7009;
  background: #fff;
  box-shadow: 0 6rpx 16rpx rgba(255, 112, 9, 0.1);
}
.grid-item .icon-box.path-style.data-v-5571075f {
  background-color: #FFF5EE;
}
.grid-item .item-text.data-v-5571075f {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
.grid-item.disabled.data-v-5571075f {
  pointer-events: none;
}
.grid-item.disabled .icon-box.data-v-5571075f {
  background-color: #f8f8f8;
  border-color: #eee;
  box-shadow: none;
}
.grid-item.disabled .item-text.data-v-5571075f {
  color: #ccc;
}