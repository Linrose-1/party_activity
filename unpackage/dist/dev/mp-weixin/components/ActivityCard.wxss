/* 水平间距 */
.activity-card.data-v-f73ae0ce {
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  padding: 24rpx;
  margin: 24rpx auto;
  position: relative;
  overflow: hidden;
}

/* ── 发布者操作栏 ── */
.owner-action-bar.data-v-f73ae0ce {
  display: flex;
  flex-direction: row-reverse;
  align-items: center;
  background: #fff8f3;
  border: 1rpx solid #ffe0c8;
  border-radius: 12rpx;
  padding: 0 8rpx;
  margin-bottom: 20rpx;
  height: 60rpx;
}
.owner-btn.data-v-f73ae0ce {
  position: relative;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 0 16rpx;
}
.owner-btn text.data-v-f73ae0ce {
  font-size: 22rpx;
  color: #FF6B00;
  font-weight: 500;
}
.owner-btn--alert.data-v-f73ae0ce {
  background: linear-gradient(135deg, #FF6B00, #FF8C00);
  border-radius: 10rpx;
}
.owner-btn--alert text.data-v-f73ae0ce {
  color: #fff;
}
.owner-divider.data-v-f73ae0ce {
  width: 1rpx;
  height: 24rpx;
  background: #f0d4c0;
}
.owner-badge.data-v-f73ae0ce {
  position: absolute;
  top: -6rpx;
  right: 0;
  background: #f56c6c;
  color: #fff;
  font-size: 16rpx;
  height: 24rpx;
  min-width: 24rpx;
  line-height: 24rpx;
  text-align: center;
  border-radius: 12rpx;
  padding: 0 4rpx;
  border: 2rpx solid #fff8f3;
}
.owner-badge--white.data-v-f73ae0ce {
  background: #fff;
  color: #FF6B00;
  border-color: #FF6B00;
}

/* ── 封面区重构 ── */
.card-cover-wrapper.data-v-f73ae0ce {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.activity-image.data-v-f73ae0ce {
  width: 100%;
  aspect-ratio: 5/3.2;
  display: block;
}
.organizer-overlay.data-v-f73ae0ce {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(255, 255, 255, 0.7);
  -webkit-backdrop-filter: blur(8px);
          backdrop-filter: blur(8px);
  padding: 4rpx 12rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.organizer-overlay .org-avatar.data-v-f73ae0ce {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
}
.organizer-overlay .org-nickname.data-v-f73ae0ce {
  font-size: 18rpx;
  color: #333;
  font-weight: bold;
}
.tags-stack.data-v-f73ae0ce {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  display: flex;
  flex-direction: column;
  /* 垂直排列 */
  align-items: flex-start;
  /* 左对齐 */
  gap: 12rpx;
  /* 两个标签之间的间距 */
  z-index: 10;
}

/* 聚会类型标签 - 修改为 static（由父容器控制位置） */
.tag-overlay.data-v-f73ae0ce {
  background: rgba(255, 107, 0, 0.95);
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 10rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.2);
}
.status-tag.data-v-f73ae0ce {
  position: absolute;
  bottom: 130rpx;
  right: 20rpx;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 10rpx;
  color: #fff;
  font-weight: bold;
  z-index: 5;
  /* 增加一个微弱阴影让颜色更立体 */
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}
.title-blur-box.data-v-f73ae0ce {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.7);
  /* 70% 白底 */
  /* 强模糊 */
  -webkit-backdrop-filter: blur(60px);
  padding: 24rpx 24rpx 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 20rpx 20rpx 0 0;
}
.title-blur-box .activity-title.data-v-f73ae0ce {
  color: #000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ── 基本信息 ── */
.info-content.data-v-f73ae0ce {
  padding: 0 4rpx;
  margin-bottom: 20rpx;
}
.info-content .info-item.data-v-f73ae0ce {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  line-height: 1.4;
}
.info-content .info-label.data-v-f73ae0ce {
  color: #FF6B00;
  flex-shrink: 0;
  font-weight: 500;
}
.info-content .info-text.data-v-f73ae0ce {
  color: #666;
  flex: 1;
}

/* ── 阅读留痕 ── */
.post-view-trace.data-v-f73ae0ce {
  padding: 16rpx 0;
  border-top: 1rpx solid #f5f5f5;
  border-bottom: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.view-avatar-row.data-v-f73ae0ce {
  display: flex;
  align-items: center;
}
.tiny-avatar.data-v-f73ae0ce {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
  margin-right: -8rpx;
}
.silent-avatar.data-v-f73ae0ce {
  border: 2rpx solid #FF6B00 !important;
  background: #fff;
}
.view-count-txt.data-v-f73ae0ce {
  font-size: 20rpx;
  color: #999;
  margin-left: 20rpx;
}

/* ── 底部操作行 ── */
.card-footer.data-v-f73ae0ce {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.activity-interactions.data-v-f73ae0ce {
  display: flex;
  gap: 24rpx;
}
.activity-interactions .interaction-btn.data-v-f73ae0ce {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #888;
}
.activity-interactions .interaction-btn.data-v-f73ae0ce:active {
  opacity: 0.7;
  transform: scale(0.9);
}
.activity-interactions .interaction-btn .active.data-v-f73ae0ce {
  color: #FF6B00;
  font-weight: bold;
}
.action-buttons.data-v-f73ae0ce {
  display: flex;
  gap: 16rpx;
}
.btn-mini.data-v-f73ae0ce {
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  font-weight: bold;
}
.btn-primary.data-v-f73ae0ce {
  background: linear-gradient(to right, #FF6B00, #FF8C00);
  color: #fff;
}
.btn-primary.btn-disabled.data-v-f73ae0ce {
  background: #eee !important;
  color: #ccc;
}
.btn-favorite.data-v-f73ae0ce {
  background: #fff1e8;
  color: #FF6B00;
  gap: 6rpx;
}
.text-ellipsis.data-v-f73ae0ce {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}