/* 自定义全局主题色变量 */
.custom-fab-container.data-v-6d679bc3 {
  position: fixed;
  right: 40rpx;
  /* 关键：调高位置，避开底部 140rpx 的操作栏 */
  bottom: calc(240rpx + env(safe-area-inset-bottom));
  z-index: 1001;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

/* 主按钮样式 */
.fab-main-btn.data-v-6d679bc3 {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF8C00, #FF6A00);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 106, 0, 0.4);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.fab-main-btn .main-text.data-v-6d679bc3 {
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
}
.fab-main-btn.data-v-6d679bc3:active {
  transform: scale(0.9);
}
.btn-active.data-v-6d679bc3 {
  transform: rotate(90deg);
  background: #333;
  /* 展开后变色，增加对比度 */
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

/* 菜单项容器 */
.fab-menu.data-v-6d679bc3 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 20rpx;
  opacity: 0;
  transform: translateY(20rpx) scale(0.8);
  pointer-events: none;
  transition: all 0.3s ease;
}
.menu-active.data-v-6d679bc3 {
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: auto;
}

/* 单个菜单项样式 */
.menu-item.data-v-6d679bc3 {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  padding: 10rpx 24rpx 10rpx 10rpx;
  border-radius: 60rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid #eee;
}
.menu-item.data-v-6d679bc3:active {
  background: #f0f0f0;
}
.menu-item .item-icon.data-v-6d679bc3 {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}
.menu-item .item-text.data-v-6d679bc3 {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  white-space: nowrap;
}

/* 图标背景色 */
.bg-orange.data-v-6d679bc3 {
  background: linear-gradient(135deg, #ffaa00 0%, #fee526 100%);
}
.bg-blue.data-v-6d679bc3 {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}
.bg-green.data-v-6d679bc3 {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}
.bg-purple.data-v-6d679bc3 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}