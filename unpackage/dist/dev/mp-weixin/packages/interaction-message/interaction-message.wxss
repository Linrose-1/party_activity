/* 水平间距 */
/* 自定义全局主题色变量 */
.interaction-page.data-v-c723bf2a {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f4f5f7;
}
.privacy-notice.data-v-c723bf2a {
  background: #fffbe6;
  padding: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #ed6a0c;
  border-bottom: 1rpx solid #ffe58f;
  flex-shrink: 0;
}

/* scroll-view 撑满剩余高度 */
.chat-list.data-v-c723bf2a {
  flex: 1;
  padding: 30rpx 30rpx 0;
  box-sizing: border-box;
  overflow: hidden;
}
.message-container.data-v-c723bf2a {
  padding-bottom: 20rpx;
}
.message-group.data-v-c723bf2a {
  display: flex;
  margin-bottom: 40rpx;
}
.message-group .user-avatar.data-v-c723bf2a {
  width: 84rpx;
  height: 84rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #eee;
  flex-shrink: 0;
}
.message-group .message-content-box.data-v-c723bf2a {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  max-width: 75%;
}
.message-group .user-name.data-v-c723bf2a {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  margin-left: 4rpx;
}
.message-group .bubble.data-v-c723bf2a {
  background: #fff;
  padding: 20rpx 28rpx;
  border-radius: 4rpx 28rpx 28rpx 28rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
  word-break: break-all;
}
.message-group .bubble .text-content.data-v-c723bf2a {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}
.message-group .message-time.data-v-c723bf2a {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 12rpx;
  margin-left: 4rpx;
}
.message-group.is-me.data-v-c723bf2a {
  flex-direction: row-reverse;
}
.message-group.is-me .user-avatar.data-v-c723bf2a {
  margin-right: 0;
  margin-left: 20rpx;
}
.message-group.is-me .message-content-box.data-v-c723bf2a {
  align-items: flex-end;
}
.message-group.is-me .bubble.data-v-c723bf2a {
  background: #FF730E;
  border-radius: 28rpx 4rpx 28rpx 28rpx;
}
.message-group.is-me .bubble .text-content.data-v-c723bf2a {
  color: #fff;
}
.message-group.is-me .message-time.data-v-c723bf2a,
.message-group.is-me .user-name.data-v-c723bf2a {
  margin-left: 0;
  margin-right: 4rpx;
}

/* 输入栏：fixed 定位保持贴底 */
.input-footer.data-v-c723bf2a {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-top: 1rpx solid #eee;
  z-index: 100;
}
.input-footer .input-wrapper.data-v-c723bf2a {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
}
.input-footer .main-input.data-v-c723bf2a {
  flex: 1;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  font-size: 30rpx;
  max-height: 200rpx;
  min-height: 40rpx;
  box-sizing: border-box;
}
.input-footer .send-btn.data-v-c723bf2a {
  background: #e0e0e0;
  color: #fff;
  width: 120rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.2s;
  flex-shrink: 0;
}
.input-footer .send-btn.active.data-v-c723bf2a {
  background: #FF730E;
  box-shadow: 0 4rpx 10rpx rgba(255, 115, 14, 0.2);
}
.input-footer .send-btn.data-v-c723bf2a:active {
  opacity: 0.8;
}
.empty-state.data-v-c723bf2a {
  padding-top: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #ccc;
  font-size: 26rpx;
  gap: 20rpx;
}