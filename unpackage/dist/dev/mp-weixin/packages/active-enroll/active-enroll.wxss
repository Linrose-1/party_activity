/* 水平间距 */
/* 水平间距 */
.page.data-v-3a3637dc {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 60rpx;
}

/* 顶部 Banner */
.header-banner.data-v-3a3637dc {
  background: linear-gradient(135deg, #FF62B1 0%, #ff2f98 100%);
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.header-banner .header-title.data-v-3a3637dc {
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  padding: 0 40rpx;
  text-align: center;
}

/* 步骤指示器 */
.step-indicator.data-v-3a3637dc {
  display: flex;
  justify-content: center;
  margin: -40rpx 30rpx 30rpx;
  background: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.step-indicator .step.data-v-3a3637dc {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}
.step-indicator .step.active .step-circle.data-v-3a3637dc {
  background: #FF62B1;
}
.step-indicator .step.active .step-text.data-v-3a3637dc {
  color: #FF62B1;
  font-weight: bold;
}
.step-indicator .step.data-v-3a3637dc:not(:last-child)::after {
  content: "";
  position: absolute;
  top: 30rpx;
  right: -50%;
  width: 100%;
  height: 2rpx;
  background: #eee;
  z-index: 1;
}
.step-indicator .step-circle.data-v-3a3637dc {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  z-index: 2;
  margin-bottom: 10rpx;
}
.step-indicator .step-text.data-v-3a3637dc {
  font-size: 24rpx;
  color: #999;
}

/* 通用卡片 */
.section-card.data-v-3a3637dc {
  background: #fff;
  margin: 24rpx;
  padding: 30rpx;
  border-radius: 20rpx;
}
.section-card .section-header.data-v-3a3637dc {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-card .section-header .header-mark.data-v-3a3637dc {
  width: 8rpx;
  height: 32rpx;
  background: #FF62B1;
  border-radius: 4rpx;
  margin-right: 16rpx;
}
.section-card .section-header .section-title.data-v-3a3637dc {
  font-size: 30rpx;
  font-weight: bold;
  color: #FF62B1;
}
.section-card .section-header .price-tag.data-v-3a3637dc {
  margin-left: auto;
  color: #ff1a3c;
  font-size: 36rpx;
  font-weight: bold;
}

/* 信息展示与表单 */
.info-content.data-v-3a3637dc {
  background: #fff9fb;
  padding: 20rpx;
  border-radius: 12rpx;
}
.info-content .info-row.data-v-3a3637dc {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}
.info-content .info-row .label.data-v-3a3637dc {
  color: #FF62B1;
  width: 140rpx;
}
.info-content .info-row .val.data-v-3a3637dc {
  color: #555;
  flex: 1;
}
.input-item.data-v-3a3637dc {
  margin-bottom: 30rpx;
}
.input-item .form-label.data-v-3a3637dc {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

/* 支付与上传 */
.payment-box.data-v-3a3637dc {
  text-align: center;
  padding: 40rpx;
  background: #fafafa;
  border-radius: 20rpx;
}
.payment-box .qr-image.data-v-3a3637dc {
  width: 320rpx;
  height: 320rpx;
  border: 1rpx solid #eee;
}
.payment-box .qr-tip.data-v-3a3637dc {
  display: block;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #FF62B1;
  font-weight: bold;
}
.upload-area.data-v-3a3637dc {
  width: 100%;
  height: 360rpx;
  background: #fdfdfd;
  border: 2rpx dashed #ddd;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.upload-area .preview-img.data-v-3a3637dc {
  width: 100%;
  height: 100%;
}
.upload-area .upload-placeholder.data-v-3a3637dc {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
  font-size: 26rpx;
  gap: 10rpx;
}
.prompt-text.data-v-3a3637dc {
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  display: block;
}

/* 按钮 */
.action-btn.data-v-3a3637dc {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(to right, #FF62B1, #ff49a4);
  color: #fff;
  border-radius: 45rpx;
  font-weight: bold;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}
.action-btn.btn-disabled.data-v-3a3637dc {
  background: #e0e0e0 !important;
  color: #fff;
}
.action-btn.outline.data-v-3a3637dc {
  background: #fff;
  color: #FF62B1;
  border: 2rpx solid #FF62B1;
}

/* 邀请码弹窗 */
