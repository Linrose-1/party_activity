/* 水平间距 */
.container.data-v-bcbcdbe7 {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 30rpx;
}
.menu-list.data-v-bcbcdbe7 {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}
.menu-item.data-v-bcbcdbe7 {
  display: flex;
  align-items: center;
  padding: 36rpx 30rpx;
  border-bottom: 1rpx solid #f9f9f9;
  position: relative;
}
.menu-item.data-v-bcbcdbe7:active {
  background-color: #fafafa;
}
.menu-item.data-v-bcbcdbe7:last-child {
  border-bottom: none;
}
.icon-box.data-v-bcbcdbe7 {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}
.icon-box.review.data-v-bcbcdbe7 {
  background: linear-gradient(135deg, #FF9A9E, #fecfef);
}
.icon-box.hunter.data-v-bcbcdbe7 {
  background: linear-gradient(135deg, #a18cd1, #fbc2eb);
}
.icon-box.business.data-v-bcbcdbe7 {
  background: linear-gradient(135deg, #84fab0, #8fd3f4);
}
.content.data-v-bcbcdbe7 {
  flex: 1;
}
.content .title.data-v-bcbcdbe7 {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}
.content .desc.data-v-bcbcdbe7 {
  font-size: 24rpx;
  color: #999;
}

/* 角标样式优化：更显眼的数字红点 */
.badge.data-v-bcbcdbe7 {
  background-color: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 18rpx;
  padding: 0 10rpx;
  margin-right: 14rpx;
  box-shadow: 0 4rpx 8rpx rgba(255, 77, 79, 0.3);
}