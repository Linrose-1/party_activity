/* 自定义全局主题色变量 */
.container.data-v-008c2f84 {
  min-height: 100vh;
  background-color: #F8F9FB;
  padding-bottom: 60rpx;
}

/* 顶部背景 */
.header-bg.data-v-008c2f84 {
  background: linear-gradient(135deg, #FF62B1 0%, #FF85C1 100%);
  height: 200rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  border-radius: 0 0 60rpx 60rpx;
}
.header-content .title.data-v-008c2f84 {
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
  display: block;
  letter-spacing: 2rpx;
}
.header-content .subtitle.data-v-008c2f84 {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  margin-top: 10rpx;
  display: block;
}

/* 列表区域 */
.sponsor-list.data-v-008c2f84 {
  padding: 0 30rpx;
  margin-top: -40rpx;
}
.sponsor-card.data-v-008c2f84 {
  position: relative;
  background-color: #fff;
  border-radius: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.03);
  overflow: hidden;
}
.sponsor-card.data-v-008c2f84:active {
  transform: scale(0.98);
  background-color: #fafafa;
}
.sponsor-card .rank-tag.data-v-008c2f84 {
  position: absolute;
  top: 0;
  left: 0;
  background: rgba(255, 98, 177, 0.1);
  color: #FF62B1;
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 16rpx;
  border-radius: 0 0 20rpx 0;
}
.card-inner.data-v-008c2f84 {
  display: flex;
  align-items: center;
  padding: 30rpx;
  padding-left: 40rpx;
}
.card-inner .sp-logo.data-v-008c2f84 {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid #F0F0F0;
  flex-shrink: 0;
}
.card-inner .sp-info.data-v-008c2f84 {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}
.card-inner .sp-info .sp-name.data-v-008c2f84 {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}
.card-inner .sp-info .sp-intro.data-v-008c2f84 {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}
.tag-row.data-v-008c2f84 {
  display: flex;
  margin-top: 12rpx;
}
.tag-row .type-tag.data-v-008c2f84 {
  font-size: 20rpx;
  color: #FF62B1;
  background: rgba(255, 98, 177, 0.08);
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
  border: 1rpx solid rgba(255, 98, 177, 0.2);
}
.arrow-box.data-v-008c2f84 {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-left: 20rpx;
}
.arrow-box .view-txt.data-v-008c2f84 {
  font-size: 22rpx;
  color: #FF62B1;
  font-weight: bold;
}
.text-ellipsis.data-v-008c2f84 {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.empty-state.data-v-008c2f84 {
  padding-top: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #ccc;
  font-size: 28rpx;
  gap: 20rpx;
}
.footer-tip.data-v-008c2f84 {
  text-align: center;
  font-size: 22rpx;
  color: #ddd;
  margin-top: 60rpx;
  letter-spacing: 2rpx;
}