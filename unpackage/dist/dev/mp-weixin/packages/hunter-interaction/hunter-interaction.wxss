/* 自定义全局主题色变量 */
.interaction-container.data-v-d063ca4b {
  min-height: 100vh;
  background-color: #f8f9fa;
  display: flex;
  flex-direction: column;
}

/* 顶部 Tab 样式 */
.tab-header.data-v-d063ca4b {
  display: flex;
  background-color: #fff;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 0 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.tab-header .tab-item.data-v-d063ca4b {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}
.tab-header .tab-item.active.data-v-d063ca4b {
  color: #FF7901;
  font-weight: bold;
  font-size: 30rpx;
}
.tab-header .tab-item.active .tab-line.data-v-d063ca4b {
  opacity: 1;
  transform: translateX(-50%) scaleX(1);
}
.tab-header .tab-item .tab-line.data-v-d063ca4b {
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 40rpx;
  height: 6rpx;
  background-color: #FF7901;
  border-radius: 4rpx;
  opacity: 0;
  transform: translateX(-50%) scaleX(0);
  transition: all 0.3s;
}

/* 列表区域 */
.list-wrapper.data-v-d063ca4b {
  padding: 30rpx;
}
.interaction-card.data-v-d063ca4b {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}
.card-top.data-v-d063ca4b {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  justify-content: space-between;
}
.avatar-box.data-v-d063ca4b {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  flex-shrink: 0;
}
.avatar-box .user-avatar.data-v-d063ca4b {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx solid #f0f0f0;
  background-color: #f8f8f8;
}
.avatar-box .v-badge.data-v-d063ca4b {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 32rpx;
  height: 32rpx;
}
.user-meta.data-v-d063ca4b {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}
.user-meta .name-row.data-v-d063ca4b {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.user-meta .name-row .user-name.data-v-d063ca4b {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.user-meta .name-row .cert-tag.data-v-d063ca4b {
  font-size: 18rpx;
  color: #52c41a;
  background: rgba(82, 196, 26, 0.1);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}
.user-meta .interaction-time.data-v-d063ca4b {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
  display: block;
}

/* 按钮与未读数 */
.card-right-action.data-v-d063ca4b {
  margin-left: 20rpx;
}
.message-btn-box.data-v-d063ca4b {
  position: relative;
  background-color: rgba(255, 121, 1, 0.08);
  border: 1rpx solid rgba(255, 121, 1, 0.15);
  border-radius: 40rpx;
  padding: 14rpx 28rpx;
}
.message-btn-box.data-v-d063ca4b:active {
  opacity: 0.7;
  transform: scale(0.95);
}
.message-btn-box .btn-content.data-v-d063ca4b {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.message-btn-box .btn-txt.data-v-d063ca4b {
  font-size: 24rpx;
  color: #FF7901;
  font-weight: bold;
}
.unread-badge.data-v-d063ca4b {
  position: absolute;
  top: -12rpx;
  right: -6rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 18rpx;
  font-weight: bold;
  min-width: 30rpx;
  height: 30rpx;
  line-height: 30rpx;
  text-align: center;
  border-radius: 15rpx;
  padding: 0 8rpx;
  border: 3rpx solid #fff;
}

/* 底部背景块 */
.post-context.data-v-d063ca4b {
  background-color: #f9f9f9;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.post-context .context-label.data-v-d063ca4b {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
}
.post-context .post-title.data-v-d063ca4b {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.empty-box.data-v-d063ca4b {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  color: #ccc;
  font-size: 26rpx;
  gap: 20rpx;
}