/* 水平间距 */
/* 自定义全局主题色变量 */
.interaction-container.data-v-d063ca4b {
  min-height: 100vh;
  background-color: #f8f9fa;
}

/* 顶部统计 */
.header-stats.data-v-d063ca4b {
  background: linear-gradient(135deg, #FF7901, #FF9533);
  padding: 60rpx 40rpx;
  color: white;
  border-radius: 0 0 40rpx 40rpx;
}
.header-stats .stats-content.data-v-d063ca4b {
  display: flex;
  flex-direction: column;
}
.header-stats .stats-content .stats-num.data-v-d063ca4b {
  font-size: 64rpx;
  font-weight: bold;
}
.header-stats .stats-content .stats-label.data-v-d063ca4b {
  font-size: 28rpx;
  opacity: 0.9;
  margin-top: 10rpx;
}

/* 列表区域 */
.list-wrapper.data-v-d063ca4b {
  padding: 30rpx;
  margin-top: -30rpx;
}
.interaction-card.data-v-d063ca4b {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.card-top.data-v-d063ca4b {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.avatar-box.data-v-d063ca4b {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-right: 20rpx;
}
.avatar-box .user-avatar.data-v-d063ca4b {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx solid #eee;
}
.avatar-box .v-badge.data-v-d063ca4b {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 32rpx;
  height: 32rpx;
}
.user-meta.data-v-d063ca4b {
  flex: 1;
}
.user-meta .name-row.data-v-d063ca4b {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.user-meta .name-row .user-name.data-v-d063ca4b {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.user-meta .name-row .cert-tag.data-v-d063ca4b {
  font-size: 20rpx;
  color: #52c41a;
  background: #f6ffed;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}
.user-meta .interaction-time.data-v-d063ca4b {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}
.action-btn.data-v-d063ca4b {
  background-color: rgba(255, 121, 1, 0.1);
  color: #FF7901;
  font-size: 24rpx;
  font-weight: 500;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}
.action-btn.data-v-d063ca4b:active {
  opacity: 0.7;
}

/* 关联商机背景块 */
.post-context.data-v-d063ca4b {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.post-context .context-label.data-v-d063ca4b {
  font-size: 24rpx;
  color: #888;
  white-space: nowrap;
}
.post-context .post-title.data-v-d063ca4b {
  flex: 1;
  font-size: 24rpx;
  color: #555;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.empty-box.data-v-d063ca4b {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  color: #ccc;
  font-size: 26rpx;
  gap: 20rpx;
}