/* 基本资料网格 */
.info-grid.data-v-991800d7 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}
.info-grid .info-item.data-v-991800d7 {
  background-color: #f8fafc;
  padding: 24rpx;
  border-radius: 16rpx;
}
.info-grid .info-item.avatar-box.data-v-991800d7 {
  grid-column: span 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.info-grid .avatar-value.data-v-991800d7 {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
