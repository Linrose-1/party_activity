l}}"></uni-icons><text class="data-v-d495462d">{{dim.m}}</text></view></view></view></view><view class="rule-card data-v-d495462d"><view class="section-title data-v-d495462d"><view class="title-line data-v-d495462d"></view><text class="data-v-d495462d">等级划分说明</text></view><view class="rule-list data-v-d495462d"><view wx:for="{{h}}" wx:for-item="rule" wx:key="d" class="{{['rule-item', 'data-v-d495462d', rule.e && 'active']}}"><text class="rule-icon data-v-d495462d">{{rule.a}}</text><text class="rule-name data-v-d495462d">{{rule.b}}</text><text class="rule-range data-v-d495462d">{{rule.c}}分</text></view></view></view><uni-popup wx:if="{{m}}" class="r data-v-d495462d" u-s="{{['d']}}" u-r="rulesPopup" u-i="d495462d-4" bind:__l="__l" u-p="{{m}}"><view class="rules-modal data-v-d495462d"><view class="modal-header data-v-d495462d"><text class="data-v-d495462d">猩球信用评分规则</text><uni-icons wx:if="{{j}}" class="data-v-d495462d" bindclick="{{i}}" u-i="d495462d-5,d495462d-4" bind:__l="__l" u-p="{{j}}"></uni-icons></view><scroll-view scroll-y class="rules-content data-v-d495462d"><view class="scroll-inner data-v-d495462d"><view class="formula-box data-v-d495462d"><text class="formula-title data-v-d495462d">总分计算公式</text><text class="formula-text data-v-d495462d">总信用分 = 贡分权重 + 智米权重 + 商友互动权重 + 数字身份权重 + 基础信息权重 + 实名认证权重</text></view><view class="rule-detail-item data-v-d495462d"><view class="detail-label data-v-d495462d">1. 贡分权重（最高300分）</view><view class="detail-desc data-v-d495462d">1贡分 = 0.01信用分。达到3万贡分即得满分。</view></view><view class="rule-detail-item data-v-d495462d"><view class="detail-label data-v-d495462d">2. 智米权重（最高200分）</view><view class="detail-desc data-v-d495462d">1智米 = 0.02信用分。达到1万智米即得满分。</view></view><view class="rule-detail-item data-v-d495462d"><view class="detail-label data-v-d495462d">3. 商友赞踩（最高200分）</view><view class="detail-desc data-v-d495462d">获赞数 × 2分（上限200分）；被踩数 × -5分（不设下限）。</view></view><view class="rule-detail-item data-v-d495462d"><view class="detail-label data-v-d495462d">4. 数字评价（最高100分）</view><view class="detail-desc data-v-d495462d">该评分为数字评价统计映射。</view></view><view class="rule-detail-item data-v-d495462d"><view class="detail-label data-v-d495462d">5. 基础信息（最高150分）</view><view class="info-grid data-v-d495462d"><view class="grid-item data-v-d495462d">昵称(+20)</view><view class="grid-item data-v-d495462d">头像(+20)</view><view class="grid-item data-v-d495462d">性别(+10)</view><view class="grid-item data-v-d495462d">生日(+10)</view><view class="grid-item data-v-d495462d">联系邮箱(+20)</view><view class="grid-item data-v-d495462d">公司网站(+15)</view><view class="grid-item data-v-d495462d">微信码(+25)</view><view class="grid-item data-v-d495462d">商协会(+10)</view><view class="grid-item data-v-d495462d">职业状态(+20)</view></view></view><view class="rule-detail-item data-v-d495462d"><view class="detail-label data-v-d495462d">6. 实名认证（最高50分）</view><view class="detail-desc data-v-d495462d">完成实名认证直接获得 50分。</view></view><view class="data-v-d495462d" style="height:40rpx"></view></view></scroll-view><view class="modal-footer data-v-d495462d"><button class="know-btn data-v-d495462d" bindtap="{{k}}">我知道了</button></view></view></uni-popup><view class="bottom-spacer data-v-d495462d"></view></view>