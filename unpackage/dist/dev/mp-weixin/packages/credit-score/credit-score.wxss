/* 水平间距 */
/* 水平间距 */
.credit-container.data-v-d495462d {
  background-color: #F8F9FB;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 头部样式 */
.header-card.data-v-d495462d {
  background: linear-gradient(135deg, #2D2D2D 0%, #1A1A1A 100%);
  height: 520rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #FFF;
  border-radius: 0 0 80rpx 80rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}
.header-card .score-circle.data-v-d495462d {
  width: 240rpx;
  height: 240rpx;
  border: 6rpx solid rgba(255, 131, 0, 0.3);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 131, 0, 0.05);
  box-shadow: 0 0 40rpx rgba(255, 131, 0, 0.1);
}
.header-card .score-circle .score-num.data-v-d495462d {
  font-size: 80rpx;
  font-weight: bold;
  color: #FF8300;
  line-height: 1;
}
.header-card .score-circle .score-label.data-v-d495462d {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}
.header-card .level-badge.data-v-d495462d {
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.1);
  padding: 10rpx 40rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}
.header-card .level-badge .level-icon.data-v-d495462d {
  font-size: 32rpx;
}
.header-card .level-badge .level-name.data-v-d495462d {
  font-size: 30rpx;
  font-weight: bold;
  color: #FFBD70;
}
.header-card .update-tip.data-v-d495462d {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 30rpx;
  text-decoration: underline;
}

/* 标题样式 */
.section-title.data-v-d495462d {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}
.section-title .title-line.data-v-d495462d {
  width: 8rpx;
  height: 32rpx;
  background: #FF8300;
  border-radius: 4rpx;
  margin-right: 16rpx;
}
.section-title text.data-v-d495462d {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 维度列表样式 */
.dimension-section.data-v-d495462d {
  margin: -40rpx 30rpx 30rpx;
  background: #FFF;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.dimension-section .dimension-list .dimension-item.data-v-d495462d {
  margin-bottom: 36rpx;
}
.dimension-section .dimension-list .dimension-item.data-v-d495462d:last-child {
  margin-bottom: 0;
}
.dimension-section .dimension-list .dimension-item .item-top.data-v-d495462d {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.dimension-section .dimension-list .dimension-item .item-top .label-group.data-v-d495462d {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.dimension-section .dimension-list .dimension-item .item-top .label-group .label.data-v-d495462d {
  font-size: 28rpx;
  color: #444;
  font-weight: 500;
}
.dimension-section .dimension-list .dimension-item .item-top .value.data-v-d495462d {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
.dimension-section .dimension-list .dimension-item .item-top .value .max.data-v-d495462d {
  font-size: 22rpx;
  color: #999;
  font-weight: normal;
}
.dimension-section .dimension-list .dimension-item .progress-bg.data-v-d495462d {
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}
.dimension-section .dimension-list .dimension-item .progress-bg .progress-bar.data-v-d495462d {
  height: 100%;
  background: linear-gradient(90deg, #FFBD70, #FF8300);
  border-radius: 6rpx;
  transition: width 0.6s ease;
}

/* 规则卡片样式 */
.rule-card.data-v-d495462d {
  margin: 0 30rpx;
  background: #FFF;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.rule-card .rule-list .rule-item.data-v-d495462d {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.rule-card .rule-list .rule-item.data-v-d495462d:last-child {
  border-bottom: none;
}
.rule-card .rule-list .rule-item.active.data-v-d495462d {
  background: rgba(255, 131, 0, 0.05);
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  margin: 0 -10rpx;
}
.rule-card .rule-list .rule-item.active .rule-name.data-v-d495462d {
  color: #FF8300;
}
.rule-card .rule-list .rule-item .rule-icon.data-v-d495462d {
  font-size: 36rpx;
  width: 60rpx;
}
.rule-card .rule-list .rule-item .rule-name.data-v-d495462d {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  margin-left: 20rpx;
}
.rule-card .rule-list .rule-item .rule-range.data-v-d495462d {
  font-size: 26rpx;
  color: #999;
  font-family: Arial;
}

/* =========================================
   规则弹窗 UI 深度优化版
   ========================================= */
.rules-modal.data-v-d495462d {
  height: 80vh;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  overflow: hidden;
}
.modal-header.data-v-d495462d {
  flex-shrink: 0;
  padding: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
}
.modal-header text.data-v-d495462d {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}
.rules-content.data-v-d495462d {
  flex: 1;
  height: 0;
  /* 强制 flex 子元素重新计算高度以支持内部滚动 */
  width: 100%;
}
.scroll-inner.data-v-d495462d {
  padding: 30rpx 40rpx;
}
.formula-box.data-v-d495462d {
  background-color: #FFF9F2;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(255, 131, 0, 0.1);
}
.formula-box .formula-title.data-v-d495462d {
  display: block;
  font-size: 28rpx;
  color: #FF8300;
  font-weight: bold;
  margin-bottom: 12rpx;
}
.formula-box .formula-text.data-v-d495462d {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
.rule-detail-item.data-v-d495462d {
  margin-bottom: 40rpx;
}
.rule-detail-item .detail-label.data-v-d495462d {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.rule-detail-item .detail-desc.data-v-d495462d {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
.info-grid.data-v-d495462d {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  background-color: #f9f9f9;
  padding: 24rpx;
  border-radius: 16rpx;
}
.info-grid .grid-item.data-v-d495462d {
  font-size: 22rpx;
  color: #777;
  background: #fff;
  padding: 12rpx 0;
  text-align: center;
  border-radius: 8rpx;
  border: 1rpx solid #eee;
}
.modal-footer.data-v-d495462d {
  flex-shrink: 0;
  padding: 30rpx 40rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #f5f5f5;
}
.modal-footer .know-btn.data-v-d495462d {
  background: linear-gradient(135deg, #FFBD70, #FF8300);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-weight: bold;
}
.modal-footer .know-btn.data-v-d495462d::after {
  border: none;
}
.bottom-spacer.data-v-d495462d {
  height: 60rpx;
}