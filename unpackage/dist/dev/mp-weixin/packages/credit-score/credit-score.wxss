/* ══════════════════════════════════════════
   规则弹窗
   关键修复：uni-popup background-color="#ffffff"
   + rules-modal 不设透明背景，底部不再镂空
   ══════════════════════════════════════════ */
.rules-modal.data-v-d495462d {
  /* 弹窗高度占屏幕 80%，内部使用 flex 布局分区 */
  height: 80vh;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  overflow: hidden;
}

/* 弹窗头部：标题 + 关闭按钮 */
.modal-header.data-v-d495462d {
  flex-shrink: 0;
  padding: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
}
.modal-header text.data-v-d495462d {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

/* 弹窗可滚动内容区，flex: 1 撑满剩余空间 */
.rules-content.data-v-d495462d {
  flex: 1;
  height: 0;
  /* 配合 flex 使内部可独立滚动 */
  width: 100%;
}
.scroll-inner.data-v-d495462d {
  padding: 30rpx 40rpx;
}

/* 总分公式高亮框 */
